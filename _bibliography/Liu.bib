@article{chariandySchlierenImageryVelocimetry2026,
  title = {Schlieren Imagery and Velocimetry of Electrohydrodynamic Heat Transfer Enhancement in an Organic Phase Change Material},
  author = {Chariandy, Ethan and Liu, Siwei and Sato, Takehiko and Nakajima, Tomoki and Cotton, James S.},
